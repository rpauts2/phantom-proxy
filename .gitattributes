# =============================================================================
# PhantomProxy Pro - Git Attributes
# Controls line endings, binary files, and diff settings
# Last Updated: February 20, 2026
# =============================================================================

# -----------------------------------------------------------------------------
# Line Endings (Normalize to LF for cross-platform consistency)
# -----------------------------------------------------------------------------
# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Explicitly declare source files to normalize
*.go text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell scripts on Unix should be LF
*.sh text eol=lf

# -----------------------------------------------------------------------------
# Binary Files (No normalization)
# -----------------------------------------------------------------------------
# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.bmp binary
*.webp binary
*.tiff binary

# Documents
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.rar binary
*.7z binary

# Executables
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.bin binary

# Certificates & Keys
*.key binary
*.pem binary
*.crt binary
*.p12 binary
*.pfx binary
*.jks binary

# Database files
*.db binary
*.sqlite binary
*.sqlite3 binary

# -----------------------------------------------------------------------------
# Diff Settings
# -----------------------------------------------------------------------------
# Use appropriate diff drivers for various file types
*.go diff=go
*.py diff=python
*.js diff=javascript
*.ts diff=typescript
*.jsx diff=javascript
*.tsx diff=typescript
*.html diff=html
*.css diff=css
*.scss diff=css
*.json diff=json
*.yaml diff=yaml
*.yml diff=yaml
*.md diff=markdown

# Custom diff for large files
*.log diff=nop
*.csv diff=csv

# -----------------------------------------------------------------------------
# Merge Strategies
# -----------------------------------------------------------------------------
# Use union merge for certain file types
*.lock merge=union
go.sum merge=union

# -----------------------------------------------------------------------------
# Export Ignore (for git archive)
# -----------------------------------------------------------------------------
.gitignore export-ignore
.gitattributes export-ignore
.editorconfig export-ignore
.github/ export-ignore
.gitlab-ci.yml export-ignore
.travis.yml export-ignore
Dockerfile export-ignore
docker-compose*.yml export-ignore
Makefile export-ignore
*.md export-ignore
docs/ export-ignore
tests/ export-ignore
test/ export-ignore

# -----------------------------------------------------------------------------
# Large File Storage (Git LFS)
# Uncomment if using Git LFS
# -----------------------------------------------------------------------------
# *.png filter=lfs diff=lfs merge=lfs -text
# *.jpg filter=lfs diff=lfs merge=lfs -text
# *.gif filter=lfs diff=lfs merge=lfs -text
# *.mp4 filter=lfs diff=lfs merge=lfs -text
# *.mov filter=lfs diff=lfs merge=lfs -text
# *.zip filter=lfs diff=lfs merge=lfs -text

# -----------------------------------------------------------------------------
# Whitespace Checks
# -----------------------------------------------------------------------------
# Warn on trailing whitespace
text eol=lf whitespace=warn-at-eol

# End of .gitattributes
