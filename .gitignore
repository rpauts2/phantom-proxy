# =============================================================================
# PhantomProxy Pro - Professional .gitignore
# Last Updated: February 20, 2026
# =============================================================================

# -----------------------------------------------------------------------------
# Git & Version Control
# -----------------------------------------------------------------------------
.git/
.gitignore
*.orig
*.patch
*.diff

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
# Bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# Virtual environments
venv/
env/
ENV/
.venv/
.conda/

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg

# Installers
*.exe
*.dmg
*.app

# Package managers
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Go
# -----------------------------------------------------------------------------
# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Dependency directories
vendor/

# Go workspace file
go.work

# Output files
*.out
*.test

# Coverage
*.cover
*.coverprofile

# -----------------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------------
# JetBrains IDEs
.idea/
*.iml
*.ipr
*.iws

# VS Code
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace
*.sublime-*

# Vim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Temporary files
*.tmp
*.temp
*.bak
*.swp

# -----------------------------------------------------------------------------
# Logs & Databases
# -----------------------------------------------------------------------------
*.log
logs/
*.db
*.sqlite
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal

# -----------------------------------------------------------------------------
# Environment & Configuration
# -----------------------------------------------------------------------------
# Environment variables
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# Configuration files with secrets
config.local.yaml
config.local.json
*.local.yaml
*.local.json
*.secret.yaml
*.secret.json
secrets/
credentials/

# Keys and certificates
*.key
*.pem
*.crt
*.cer
*.der
*.pfx
*.p12
*.jks
keystore.jks
truststore.jks

# AWS
.aws/
aws_credentials

# -----------------------------------------------------------------------------
# Reports & Exports
# -----------------------------------------------------------------------------
reports/
invoices/
proposals/
contracts/
evidence/
siem_exports/
scheduler_logs/
notifications/
compliance_logs/
backups/
*.pdf
*.xlsx
*.docx

# -----------------------------------------------------------------------------
# Test & Coverage
# -----------------------------------------------------------------------------
test_data/
*.test
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/
coverage.xml
*.cover

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
docs/_build/
docs/.doctrees/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Build & Compilation
# -----------------------------------------------------------------------------
bin/
obj/
*.o
*.a
*.class

# -----------------------------------------------------------------------------
# Node.js (if applicable)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# -----------------------------------------------------------------------------
# Kubernetes
# -----------------------------------------------------------------------------
*.kubeconfig
.kube/

# -----------------------------------------------------------------------------
# Stakpak Session Files
# -----------------------------------------------------------------------------
.stakpak/
.stakpak/session*

# -----------------------------------------------------------------------------
# Branding (keep placeholders)
# -----------------------------------------------------------------------------
branding/*.png
branding/*.ico
branding/*.svg
!branding/.gitkeep

# -----------------------------------------------------------------------------
# Config Templates (keep examples)
# -----------------------------------------------------------------------------
config.py
!config.example.yaml
!config.example.json

# -----------------------------------------------------------------------------
# Sensitive Directories
# -----------------------------------------------------------------------------
.internal/
.private/
backup/
dump/
export/

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------
# Thumbnail caches
thumbs.db
# Desktop configuration
desktop.ini
# Spotlight
.Spotlight-V100
.Trashes
# Jupyter
.ipynb_checkpoints

# End of .gitignore
