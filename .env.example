# PhantomProxy — copy to .env and adjust
# Go API
PHANTOM_API_KEY=change-me-to-secure-random-string
PHANTOM_DOMAIN=phantom.local

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_API_KEY=change-me-to-secure-random-string

# API (FastAPI)
DATABASE_URL=postgresql+asyncpg://phantom:phantom@localhost:5432/phantom
REDIS_URL=redis://localhost:6379/0
