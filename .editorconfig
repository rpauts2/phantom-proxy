# =============================================================================
# PhantomProxy Pro - EditorConfig
# Maintains consistent coding styles across different editors and IDEs
# https://editorconfig.org
# Last Updated: February 20, 2026
# =============================================================================

# Top-most EditorConfig file
root = true

# -----------------------------------------------------------------------------
# Default Settings (Apply to all files)
# -----------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# -----------------------------------------------------------------------------
# Markdown Files
# -----------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false

# -----------------------------------------------------------------------------
# YAML Files
# -----------------------------------------------------------------------------
[*.{yaml,yml}]
indent_size = 2

# -----------------------------------------------------------------------------
# JSON Files
# -----------------------------------------------------------------------------
[*.json]
indent_size = 2

# -----------------------------------------------------------------------------
# Shell Scripts
# -----------------------------------------------------------------------------
[*.{sh,bash}]
indent_style = space
indent_size = 4

# -----------------------------------------------------------------------------
# Batch Files (Windows)
# -----------------------------------------------------------------------------
[*.bat]
end_of_line = crlf

# -----------------------------------------------------------------------------
# Makefiles
# -----------------------------------------------------------------------------
[Makefile]
indent_style = tab

# -----------------------------------------------------------------------------
# Python Files
# -----------------------------------------------------------------------------
[*.py]
indent_size = 4
indent_style = space

# -----------------------------------------------------------------------------
# Go Files
# -----------------------------------------------------------------------------
[*.go]
indent_size = tab
indent_style = tab

# -----------------------------------------------------------------------------
# JavaScript/TypeScript Files
# -----------------------------------------------------------------------------
[*.{js,ts,jsx,tsx}]
indent_size = 2
indent_style = space

# -----------------------------------------------------------------------------
# CSS/SCSS Files
# -----------------------------------------------------------------------------
[*.{css,scss,sass,less}]
indent_size = 2
indent_style = space

# -----------------------------------------------------------------------------
# HTML Files
# -----------------------------------------------------------------------------
[*.html]
indent_size = 2
indent_style = space

# -----------------------------------------------------------------------------
# XML Files
# -----------------------------------------------------------------------------
[*.xml]
indent_size = 2
indent_style = space

# -----------------------------------------------------------------------------
# SQL Files
# -----------------------------------------------------------------------------
[*.sql]
indent_size = 4
indent_style = space

# -----------------------------------------------------------------------------
# Docker Files
# -----------------------------------------------------------------------------
[Dockerfile]
indent_size = 2
indent_style = space

# -----------------------------------------------------------------------------
# Docker Compose
# -----------------------------------------------------------------------------
[docker-compose*.yml]
indent_size = 2
indent_style = space

# -----------------------------------------------------------------------------
# Git Ignore Files
# -----------------------------------------------------------------------------
[.gitignore]
indent_style = space
indent_size = 2

# -----------------------------------------------------------------------------
# License Files
# -----------------------------------------------------------------------------
[LICENSE, LICENSE.*, COPYING, COPYING.*]
trim_trailing_whitespace = false

# -----------------------------------------------------------------------------
# Documentation Files
# -----------------------------------------------------------------------------
[docs/**/*.{md,rst}]
trim_trailing_whitespace = false

# -----------------------------------------------------------------------------
# Test Files
# -----------------------------------------------------------------------------
[tests/**/*.{py,js,ts}]
indent_size = 4

# -----------------------------------------------------------------------------
# Configuration Files
# -----------------------------------------------------------------------------
[config*.yaml, config*.json]
indent_size = 2

# End of .editorconfig
